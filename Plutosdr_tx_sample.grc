connections:
- [band_pass_filter_0, '0', iio_pluto_sink_0, '0']
- [blocks_unpack_k_bits_bb_0, '0', digital_gfsk_mod_0, '0']
- [digital_gfsk_mod_0, '0', band_pass_filter_0, '0']
- [pdu_pdu_to_tagged_stream_0, '0', blocks_unpack_k_bits_bb_0, '0']
- [pdu_random_pdu_0, pdus, satellites_hdlc_framer_0, in]
- [satellites_hdlc_framer_0, out, pdu_pdu_to_tagged_stream_0, pdus]

metadata:
  file_format: 1
  grc_version: 3.10.12.0
